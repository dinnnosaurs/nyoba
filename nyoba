<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Marine Excellence | Fish Oil Edition</title>
    <style>
        /* Modern Refactoring - Marine Theme */
        :root {
            --sea-deep: #003366;
            --omega-gold: #ffcc33;
            --coral-soft: #ff9999;
            --foam-white: #f0f8ff;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background: radial-gradient(circle at center, #005b96, #002244);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            color: white;
        }

        /* Ambient Elements */
        .balloon {
            position: absolute;
            width: 30px;
            height: 40px;
            border-radius: 50% 50% 50% 50% / 40% 40% 60% 60%;
            opacity: 0.6;
            animation: float 10s infinite ease-in;
            z-index: 1;
        }

        @keyframes float {
            0% { transform: translateY(110vh) rotate(0deg); }
            100% { transform: translateY(-20vh) rotate(360deg); }
        }

        /* 3-Tier Marine & Gold Cake */
        .cake-container {
            position: relative;
            width: 300px;
            height: 350px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-end;
            z-index: 10;
        }

        .tier {
            position: relative;
            background: linear-gradient(to bottom, #0077be, #005b96);
            border-radius: 10px 10px 5px 5px;
            box-shadow: inset 0 -5px 10px rgba(0,0,0,0.3), 0 8px 15px rgba(0,0,0,0.5);
            border: 2px solid var(--omega-gold);
        }

        .tier-1 { width: 240px; height: 90px; z-index: 3; }
        .tier-2 { width: 180px; height: 75px; z-index: 4; margin-bottom: -5px; }
        .tier-3 { width: 120px; height: 60px; z-index: 5; margin-bottom: -5px; }

        /* Golden Oil Drip Effect */
        .tier::after {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 25px;
            background: var(--omega-gold);
            border-radius: 10px 10px 80% 80% / 10px 10px 40% 40%;
            filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));
        }

        /* Candles */
        .candle-container {
            position: absolute;
            top: -45px;
            width: 100%;
            display: flex;
            justify-content: center;
            gap: 10px;
            z-index: 10;
        }

        .candle {
            width: 10px;
            height: 45px;
            background: repeating-linear-gradient(45deg, #fff, #fff 5px, var(--sea-deep) 5px, var(--sea-deep) 10px);
            border-radius: 3px;
            position: relative;
            cursor: pointer;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }

        .flame {
            position: absolute;
            top: -20px;
            left: 50%;
            transform: translateX(-50%);
            width: 16px;
            height: 24px;
            background: radial-gradient(#fff, #ffeb3b, #f44336);
            border-radius: 50% 50% 20% 20%;
            box-shadow: 0 0 20px #ffeb3b;
            animation: flicker 0.5s infinite alternate;
        }

        @keyframes flicker {
            from { transform: translateX(-50%) scale(1); opacity: 0.8; }
            to { transform: translateX(-50%) scale(1.2); opacity: 1; }
        }

        .blown .flame { display: none; }
        .blown::after {
            content: "";
            position: absolute;
            top: -15px;
            left: 50%;
            width: 2px;
            height: 10px;
            background: rgba(255,255,255,0.4);
            animation: smoke 1.5s forwards;
        }

        @keyframes smoke {
            0% { opacity: 1; transform: translateX(-50%) translateY(0); }
            100% { opacity: 0; transform: translateX(10px) translateY(-30px); }
        }

        /* Wish Message Popup */
        .wish-message {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0);
            background: var(--foam-white);
            color: var(--sea-deep);
            padding: 35px;
            border-radius: 20px;
            text-align: center;
            box-shadow: 0 0 40px rgba(0, 0, 0, 0.6), 0 0 20px var(--omega-gold);
            z-index: 1000;
            width: 85%;
            max-width: 450px;
            transition: 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            border: 4px double var(--omega-gold);
        }

        .wish-message.show { transform: translate(-50%, -50%) scale(1); }
        .wish-message h2 { font-weight: 800; margin-bottom: 15px; text-transform: uppercase; letter-spacing: 1px; }
        .wish-message p { font-size: 1.1rem; line-height: 1.6; }

        .btn {
            margin-top: 25px;
            padding: 12px 30px;
            background: var(--sea-deep);
            color: white;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            font-weight: bold;
            transition: 0.3s;
        }
        .btn:hover { background: #004a8d; transform: scale(1.05); }
    </style>
</head>
<body>

    <div class="cake-container" id="cakeContainer">
        <div class="tier tier-3">
            <div class="candle-container" id="candleGroup"></div>
        </div>
        <div class="tier tier-2"></div>
        <div class="tier tier-1"></div>
    </div>

    <div class="wish-message" id="wishPopup">
        <h2>Purification Success! ✨</h2>
        <p>Selamat ulang tahun! Semoga tahun ini membawa <b>High Quality Results</b> dalam risetmu, kelancaran beasiswa <b>LPDP</b>, dan tercapainya impian membangun <b>National Center of Excellence for Fish Oil</b>! 🐟✨</p>
        <button class="btn" onclick="closePopup()">Aamiin! ❤️</button>
    </div>

    <script>
        const totalCandles = 5;
        let blownCount = 0;

        function init() {
            const group = document.getElementById('candleGroup');
            for(let i=0; i<totalCandles; i++) {
                const c = document.createElement('div');
                c.className = 'candle';
                c.innerHTML = '<div class="flame"></div>';
                c.onclick = function() {
                    if(!this.classList.contains('blown')) {
                        this.classList.add('blown');
                        blownCount++;
                        if(blownCount === totalCandles) {
                            setTimeout(() => {
                                document.getElementById('wishPopup').classList.add('show');
                            }, 800);
                        }
                    }
                };
                group.appendChild(c);
            }

            // Create Ocean Bubbles
            for(let i=0; i<25; i++) {
                const b = document.createElement('div');
                b.className = 'balloon';
                b.style.left = Math.random() * 100 + 'vw';
                b.style.backgroundColor = `rgba(255, 255, 255, ${Math.random() * 0.4})`;
                b.style.border = "1px solid rgba(255,255,255,0.5)";
                b.style.animationDelay = Math.random() * 8 + 's';
                document.body.appendChild(b);
            }
        }

        function closePopup() {
            document.getElementById('wishPopup').classList.remove('show');
        }

        window.onload = init;
    </script>
</body>
</html>
