<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Premium Birthday Cake | Executable Success</title>
    <style>
        /* Modern Refactoring */
        :root {
            --cake-gold: #d4af37;
            --cake-cream: #f9f1d0;
            --ocean-dark: #002b36;
            --accent-pink: #ff3366;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background: radial-gradient(circle, #004d40, #001a1a);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            color: white;
        }

        /* Ambient Elements */
        .balloon {
            position: absolute;
            width: 35px;
            height: 45px;
            border-radius: 50%;
            opacity: 0.7;
            animation: float 12s infinite linear;
            z-index: 1;
        }

        @keyframes float {
            0% { transform: translateY(110vh) rotate(0deg); }
            100% { transform: translateY(-20vh) rotate(360deg); }
        }

        /* Refactored 3-Tier Golden Cake */
        .cake-container {
            position: relative;
            width: 300px;
            height: 350px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-end;
            z-index: 10;
        }

        .tier {
            position: relative;
            width: 200px;
            background: linear-gradient(to right, var(--cake-gold), #ffd700, var(--cake-gold));
            border-radius: 15px 15px 5px 5px;
            box-shadow: inset 0 -10px 15px rgba(0,0,0,0.2), 0 10px 20px rgba(0,0,0,0.4);
        }

        .tier-1 { width: 220px; height: 80px; z-index: 3; }
        .tier-2 { width: 170px; height: 70px; z-index: 4; margin-bottom: -5px; }
        .tier-3 { width: 120px; height: 60px; z-index: 5; margin-bottom: -5px; }

        /* Cream Drip Effect */
        .tier::after {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 20px;
            background: var(--cake-cream);
            border-radius: 15px 15px 100% 100% / 15px 15px 50% 50%;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        /* Candles */
        .candle-container {
            position: absolute;
            top: -40px;
            width: 100%;
            display: flex;
            justify-content: center;
            gap: 8px;
            z-index: 10;
        }

        .candle {
            width: 10px;
            height: 40px;
            background: linear-gradient(to top, #fff, var(--cake-gold));
            border-radius: 3px;
            position: relative;
            cursor: pointer;
        }

        .flame {
            position: absolute;
            top: -18px;
            left: 50%;
            transform: translateX(-50%);
            width: 14px;
            height: 22px;
            background: radial-gradient(#fff, #ffa500, #ff4500);
            border-radius: 50% 50% 20% 20%;
            box-shadow: 0 0 15px #ffcc00;
            animation: flicker 0.6s infinite alternate;
        }

        @keyframes flicker {
            from { transform: translateX(-50%) scale(1); opacity: 0.9; }
            to { transform: translateX(-50%) scale(1.1); opacity: 1; }
        }

        .blown .flame { display: none; }
        .blown::after {
            content: "☁";
            position: absolute;
            top: -20px;
            left: 0;
            font-size: 12px;
            animation: smoke 2s forwards;
            opacity: 0;
        }

        @keyframes smoke {
            0% { opacity: 0.8; transform: translateY(0); }
            100% { opacity: 0; transform: translateY(-40px) scale(2); }
        }

        /* Updated Wish Message */
        .wish-message {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0);
            background: #ffffff;
            color: #333;
            padding: 40px;
            border-radius: 15px;
            text-align: center;
            box-shadow: 0 0 50px rgba(212, 175, 55, 0.5);
            z-index: 1000;
            transition: 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .wish-message.show { transform: translate(-50%, -50%) scale(1); }

        .wish-message h2 { color: var(--ocean-dark); margin-bottom: 15px; }
        .wish-message code { background: #eee; padding: 2px 6px; border-radius: 4px; }

        .btn {
            margin-top: 20px;
            padding: 12px 25px;
            background: var(--ocean-dark);
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
        }
    </style>
</head>
<body>

    <div class="cake-container" id="cakeContainer">
        <div class="tier tier-3">
            <div class="candle-container" id="candleGroup"></div>
        </div>
        <div class="tier tier-2"></div>
        <div class="tier tier-1"></div>
    </div>

    <div class="wish-message" id="wishPopup">
        <h2>System.out.println("Success!");</h2>
        <p>Semoga tahun ini seluruh <code>commit</code> hidupmu berakhir <code>success</code>, tanpa ada <code>bug</code> di hati, dan dilancarkan jalan menuju impian terbesarmu! 🚀✨</p>
        <button class="btn" onclick="closePopup()">Terima Kasih! ❤️</button>
    </div>

    <script>
        const totalCandles = 5;
        let blownCount = 0;

        function init() {
            const group = document.getElementById('candleGroup');
            for(let i=0; i<totalCandles; i++) {
                const c = document.createElement('div');
                c.className = 'candle';
                c.innerHTML = '<div class="flame"></div>';
                c.onclick = function() {
                    if(!this.classList.contains('blown')) {
                        this.classList.add('blown');
                        blownCount++;
                        if(blownCount === totalCandles) {
                            setTimeout(() => {
                                document.getElementById('wishPopup').classList.add('show');
                            }, 800);
                        }
                    }
                };
                group.appendChild(c);
            }

            // Create Balloons
            for(let i=0; i<20; i++) {
                const b = document.createElement('div');
                b.className = 'balloon';
                b.style.left = Math.random() * 100 + 'vw';
                b.style.backgroundColor = `hsl(${Math.random() * 360}, 70%, 60%)`;
                b.style.animationDelay = Math.random() * 5 + 's';
                document.body.appendChild(b);
            }
        }

        function closePopup() {
            document.getElementById('wishPopup').classList.remove('show');
        }

        window.onload = init;
    </script>
</body>
</html>
